# Token pessoal do ClickUp (ClickUp > Configurações > Apps > API Token)
CLICKUP_API_TOKEN=

# Service account do Google Cloud com acesso ao calendário dedicado "Captação — Grupo SB"
# (compartilhar o calendário com o e-mail da service account, permissão "Fazer alterações nos eventos")
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Cole a chave privada do JSON da service account com as quebras de linha escapadas como \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Segredo para proteger o endpoint /api/sync chamado pelo cron
CRON_SECRET=

# Gestores (nome + senha + role "gestor"/"master") ficam no Vercel Edge Config, não numa
# env var — o painel Master precisa adicionar/remover gestor em tempo real, sem redeploy.
# Crie um Edge Config store ("vercel edge-config add <slug>"), conecte ao projeto e use:
EDGE_CONFIG=
# ID do mesmo Edge Config acima (ex: ecfg_xxxxx), usado pra escrever via API da Vercel.
EDGE_CONFIG_ID=
# Token pessoal da Vercel (vercel.com/account/tokens), usado só pra escrever no Edge
# Config quando o Master adiciona/remove um gestor pelo painel.
VERCEL_API_TOKEN=
